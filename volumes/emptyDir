
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: flm
spec:
  replicas: 1
  selector:
    matchLabels:
      app: flm
  template:
    metadata:
      name: mytemp
      labels:
        app: flm
    spec:
      containers:
        - name: cont1
          image: nginx
          volumeMounts:
            - mountPath: opt/cont1/
              name: devops

        - name: cont2
          image : httpd
          command : ["/bin/bash","-c","while true; do echo happy ; sleep 10;done;"]
          volumeMounts:
            - mountPath: opt/cont2/
              name: devops
      volumes:
        - name: devops
          emptyDir: {}
